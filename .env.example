# =============================================================================
# Configuration de l'application - TP2 Maintenance Connectée
# Copiez ce fichier en .env et adaptez les valeurs à votre environnement
# =============================================================================

# --- Serveur ---
PORT=3000

# --- Base de données MariaDB (installée sur le PC hôte) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tp2_maintenance_z4

# --- Automate API M580 (Schneider) ---
# IP de l'automate sur le réseau "wifi API"
MODBUS_IP=172.16.1.24
MODBUS_PORT=502

# --- Registres Modbus ---
# Température °C : %MF706 (float 32 bits sur MW706+MW707, lecture FC03)
REGISTRE_TEMPERATURE=706
# Cycle auto Zone 3 : bit %M640 de l'API Zone 3
REGISTRE_CYCLE_AUTO=640

# --- Colonne lumineuse (écriture coils FC05) ---
COIL_ROUGE=702
COIL_ORANGE=701
COIL_VERT=703

# --- Heartbeat (écriture périodique sur %MW700) ---
REGISTRE_HEARTBEAT=700
HEARTBEAT_FREQ=1000

# --- Fréquence de lecture (en secondes) ---
FREQUENCE_LECTURE=3
